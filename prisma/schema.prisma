generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum DocumentStatus {
  ACTIVE
  ARCHIVED
}

enum MinimumEducationLevel {
  NONE
  CAP_BEP
  BACCALAUREAT
  BAC_PLUS_2
  LICENCE
  MASTER
  DOCTORAT
}

enum JobStatus {
  ACTIVE
  CLOSED
  PENDING
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  EXPERIENCED
}

enum Season {
  SUMMER
  WINTER
  SPRING
  AUTUMN
  ALL_YEAR
}

enum ScheduleType {
  DAY
  NIGHT
  WEEKEND
  VARIABLE
}

enum SalaryType {
  HOURLY
  DAILY
  MONTHLY
}

enum HousingType {
  NONE
  PROVIDED
  PROVIDED_AND_PAID
}

enum JobOfferStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  CLOSED
}

enum ContractOfferType {
  CDD
  EXTRA
  INTERIM
  CDI
}

enum ApplicationJobStatus {
  PENDING
  ACCEPTED
  REJECTED
  INTERVIEW
  TEST
  PHONE
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
  DELETED
}

enum UserJobStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum NotificationType {
  INVITATION_RECEIVED      // Reçu une invitation à rejoindre un job
  JOB_ASSIGNED             // Assigné directement à un job (user existant)
  APPLICATION_RECEIVED     // Manager : nouvelle candidature sur une annonce
  APPLICATION_STATUS       // Candidat : statut de sa candidature changé
  PASSAGE_REQUEST          // Compagnie : un travailleur demande à pointer (passage)
  GENERAL                  // Message générique
}

enum RoleType {
  ADMIN
  USER
  MANAGER
}

// ─── Auth & Sessions ──────────────────────────────────────────────────────────

model Auth {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSignInAt DateTime?
  deleted      Boolean   @default(false)

  user     User      @relation(fields: [id], references: [id], onDelete: Restrict)
  sessions Session[]

  @@map("auth")
}

model Session {
  id        String   @id @default(uuid())
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  authId String @map("auth_id")
  auth   Auth   @relation(fields: [authId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  firstName     String   @map("firstname")
  lastName      String   @map("lastname")
  deleted       Boolean  @default(false)
  updatedAt     DateTime @updatedAt
  roleId        Int      @default(2)
  role          Role     @relation(fields: [roleId], references: [id])
  photoPath     String?
  city          String?
  postalCode    String?  @map("postal_code")
  phone         String?
  countryId     Int?     @map("country_id")
  country       Country? @relation(fields: [countryId], references: [id])
  languageId    Int?     @map("language_id")
  language      Language? @relation(fields: [languageId], references: [id])
  notifications Boolean  @default(true)

  auth Auth?

  companies                 Company[]        @relation("CompanyOwner")
  documents                 Document[]
  passages                  Passage[]
  createdJobs               Job[]            @relation("CreatorJobs")
  createdJobOffers          JobOffer[]       @relation("JobOfferCreator")
  announcements             Announcement[]   @relation("AnnouncementCreator")
  applications              ApplicationJob[] @relation("ApplicantJobApplications")
  processedJobApplications  ApplicationJob[] @relation("ProcessorJobApplications")
  userJobs                  UserJob[]        @relation("UserJobWorker")
  assignedJobs              UserJob[]        @relation("UserJobAssigner")
  invitationsSent           Invitation[]     @relation("InvitationsSent")
  invitationsReceived       Invitation[]     @relation("InvitationsReceived")
  notificationsReceived     Notification[]   @relation("NotificationRecipient")
  expoPushTokens            ExpoPushToken[]
  posts                     Post[]           @relation("PostAuthor")

  @@map("users")
}

// ─── Companies ────────────────────────────────────────────────────────────────

model Company {
  id String @id @default(uuid())
  name String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deleted Boolean @default(false)
  ownerId String @map("owner_id")
  addressId Int @map("address_id")
  description String?
  type String?
  phone String?

  stationId Int @map("station_id")
  station Station  @relation(fields: [stationId], references: [id])

  owner User @relation("CompanyOwner", fields: [ownerId], references: [id])
  address Address @relation(fields: [addressId], references: [id])

  jobs Job[]
  jobOffers JobOffer[]
  passages Passage[]
  defaultOptions CompanyDefaultOptions?
  companyBenefits CompanyBenefit[]
  benefitCatalog  Benefit[]
  posts           Post[]

  @@map("companies")
}

model Address {
  id        Int     @id @default(autoincrement())
  streetNumber String?
  street    String
  zipCode    String?
  locality  String
  countryId Int     @map("country_id")

  country   Country   @relation(fields: [countryId], references: [id])
  companies Company[]
  jobOffers JobOffer[]
  stationsAsOffice Station[] @relation("StationOfficeAddress")

  @@map("addresses")
}

// ─── Roles & Permissions ──────────────────────────────────────────────────────

model Role {
  id       Int    @id @default(autoincrement())
  value    String @unique
  parentId Int?
  type     RoleType @default(USER)
  parent      Role?            @relation("RoleHierarchy", fields: [parentId], references: [id])
  children    Role[]           @relation("RoleHierarchy")
  permissions PermissionRole[]
  users       User[]

  @@map("roles")
}

model Permission {
  id        Int      @id @default(autoincrement())
  value     String   @unique
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now())

  roles PermissionRole[]

  @@map("permissions")
}

model PermissionRole {
  id           Int     @id @default(autoincrement())
  deleted      Boolean @default(false)
  permissionId Int     @map("permission_id")
  roleId       Int     @map("role_id")

  permission Permission @relation(fields: [permissionId], references: [id])
  role       Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
  @@map("permission_role")
}

// ─── Job Categories ───────────────────────────────────────────────────────────

model JobCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  jobs Job[]

  @@map("job_categories")
}

// ─── Jobs ─────────────────────────────────────────────────────────────────────

model Job {
  id                   Int              @id @default(autoincrement())
  title                String
  slug                 String
  description          String?
  responsibilities     String?
  requirements         String?
  skills               String[]
  experienceLevel      ExperienceLevel? @map("experience_level")
  physicalRequirements String?          @map("physical_requirements")
  licences             String[]
  season               Season?
  transportRequired    Boolean          @default(false) @map("transport_required")
  deleted              Boolean          @default(false)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  createdBy            String           @map("created_by")
  companyId            String           @map("company_id")
  categoryId           Int?             @map("category_id")

  company   Company      @relation(fields: [companyId], references: [id])
  creator   User         @relation("CreatorJobs", fields: [createdBy], references: [id])
  category  JobCategory? @relation(fields: [categoryId], references: [id])
  tags      TagJob[]
  jobOffers JobOffer[]

  @@unique([companyId, slug])
  @@map("jobs")
}

model Tag {
  id   Int    @id @default(autoincrement())
  name String @unique

  jobs TagJob[]

  @@map("tags")
}

model TagJob {
  id      Int     @id @default(autoincrement())
  jobId   Int     @map("job_id")
  tagId   Int     @map("tag_id")
  deleted Boolean @default(false)

  job Job @relation(fields: [jobId], references: [id])
  tag Tag @relation(fields: [tagId], references: [id])

  @@map("tag_job")
}

// ─── Job Offers ───────────────────────────────────────────────────────────────

model JobOffer {
  id                  Int                @id @default(autoincrement())
  jobId               Int                @map("job_id")
  companyId           String             @map("company_id")
  createdBy           String             @map("created_by")
  title               String
  description         String?
  startDate           DateTime?          @map("start_date")
  endDate             DateTime?          @map("end_date")
  duration            Int?
  flexibleDates       Boolean            @default(false) @map("flexible_dates")
  hoursPerWeek        Float?             @map("hours_per_week")
  schedule            ScheduleType?
  addressId           Int?               @map("address_id")
  salaryType          SalaryType?        @map("salary_type")
  salaryMin           Float?             @map("salary_min")
  salaryMax           Float?             @map("salary_max")
  currency            String             @default("EUR")
  housingProvided     HousingType        @default(NONE) @map("housing_provided")
  housingCost         Float?             @map("housing_cost")
  housingDescription  String?            @map("housing_description")
  mealsProvided       Boolean            @default(false) @map("meals_provided")
  transportHelp       Boolean            @default(false) @map("transport_help")
  tips                Boolean            @default(false)
  bonus               Boolean            @default(false)
  contractType        ContractOfferType? @map("contract_type")
  applicationDeadline DateTime?          @map("application_deadline")
  status              JobOfferStatus     @default(DRAFT)
  nearTrainStation    Boolean            @default(false) @map("near_train_station")
  deleted             Boolean            @default(false)
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  job          Job              @relation(fields: [jobId], references: [id])
  company      Company          @relation(fields: [companyId], references: [id])
  creator      User             @relation("JobOfferCreator", fields: [createdBy], references: [id])
  address      Address?         @relation(fields: [addressId], references: [id])
  applications ApplicationJob[]
  userJobs     UserJob[]
  invitations  Invitation[]

  @@map("job_offers")
}

// ─── Application Jobs ─────────────────────────────────────────────────────────

model ApplicationJob {
  id          Int                  @id @default(autoincrement())
  offerId     Int                  @map("offer_id")
  userId      String               @map("user_id")
  status      ApplicationJobStatus @default(PENDING)
  message     String?
  resumeUrl   String?              @map("resume_url")
  processedBy String?              @map("processed_by")
  processedAt DateTime?            @map("processed_at")
  createdAt   DateTime             @default(now()) @map("created_at")
  deleted     Boolean              @default(false)

  offer     JobOffer @relation(fields: [offerId], references: [id])
  user      User     @relation("ApplicantJobApplications", fields: [userId], references: [id])
  processor User?    @relation("ProcessorJobApplications", fields: [processedBy], references: [id])

  @@map("application_jobs")
}

// ─── Announcements ────────────────────────────────────────────────────────────

model Announcement {
  id          Int                @id @default(autoincrement())
  title       String
  description String?
  status      AnnouncementStatus @default(DRAFT)
  publishedAt DateTime?          @map("published_at")
  createdBy   String             @map("created_by")
  deleted     Boolean            @default(false)
  createdAt   DateTime           @default(now()) @map("created_at")

  creator     User                     @relation("AnnouncementCreator", fields: [createdBy], references: [id])
  attachments AnnouncementAttachment[]

  @@map("annoucements")
}

model Attachment {
  id        Int      @id @default(autoincrement())
  filename  String
  url       String
  mimeType  String?  @map("mime_type")
  size      Int?
  createdAt DateTime @default(now()) @map("created_at")

  announcements AnnouncementAttachment[]

  @@map("attachments")
}

model AnnouncementAttachment {
  announcementId Int @map("announcement_id")
  attachmentId   Int @map("attachment_id")

  announcement Announcement @relation(fields: [announcementId], references: [id])
  attachment   Attachment   @relation(fields: [attachmentId], references: [id])

  @@id([announcementId, attachmentId])
  @@map("announcement_attachments")
}

// ─── Benefits ─────────────────────────────────────────────────────────────────

model Benefit {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  companyId   String    @map("company_id")
  deleted     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  quantity    Int?
  duration    Int?
  startDate   DateTime? @map("start_date")

  company      Company        @relation(fields: [companyId], references: [id])
  companyLinks CompanyBenefit[]

  @@map("benefits")
}

model CompanyBenefit {
  id        Int      @id @default(autoincrement())
  companyId String   @map("company_id")
  benefitId Int      @map("benefit_id")
  createdAt DateTime @default(now())
  deleted   Boolean  @default(false)

  company Company @relation(fields: [companyId], references: [id])
  benefit Benefit @relation(fields: [benefitId], references: [id])

  @@map("company_benefit")
}

// ─── Company Options ──────────────────────────────────────────────────────────

model CompanyDefaultOptions {
  id                   Int    @id @default(autoincrement())
  companyId            String @unique @map("company_id")
  maximumPassagePerDay Int    @default(1) @map("maximum_passage_per_day")

  company Company @relation(fields: [companyId], references: [id])

  @@map("company_default_options")
}

// ─── Passages ─────────────────────────────────────────────────────────────────

model Passage {
  id                  Int      @id @default(autoincrement())
  userId              String   @map("user_id")
  companyId           String   @map("company_id")
  createdAt           DateTime @default(now()) @db.Date @map("created_at")
  lastPassageThisDay  DateTime? @map("last_passage_this_day")
  countPassageThisDay Int      @default(0) @map("count_passage_this_day")

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId, createdAt])
  @@map("passages")
}

// ─── Documents ────────────────────────────────────────────────────────────────

model Document {
  id        Int            @id @default(autoincrement())
  createdAt DateTime       @default(now())
  deleted   Boolean        @default(false)
  slug      String
  status    DocumentStatus @default(ACTIVE)
  userId    String         @map("user_id")

  user User @relation(fields: [userId], references: [id])

  @@map("documents")
}

// ─── Employment ───────────────────────────────────────────────────────────────

model UserJob {
  id         Int           @id @default(autoincrement())
  userId     String        @map("user_id")
  offerId    Int           @map("offer_id")
  status     UserJobStatus @default(ACTIVE)
  assignedBy String        @map("assigned_by")
  startDate  DateTime?     @map("start_date")
  endDate    DateTime?     @map("end_date")
  createdAt  DateTime      @default(now()) @map("created_at")
  deleted    Boolean       @default(false)

  user     User     @relation("UserJobWorker", fields: [userId], references: [id])
  offer    JobOffer @relation(fields: [offerId], references: [id])
  assigner User     @relation("UserJobAssigner", fields: [assignedBy], references: [id])

  @@map("user_jobs")
}

model Invitation {
  id         Int              @id @default(autoincrement())
  token      String           @unique @default(uuid())
  email      String
  offerId    Int              @map("offer_id")
  status     InvitationStatus @default(PENDING)
  invitedBy  String           @map("invited_by")
  userId     String?          @map("user_id")
  expiresAt  DateTime         @map("expires_at")
  acceptedAt DateTime?        @map("accepted_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  deleted    Boolean          @default(false)

  offer   JobOffer @relation(fields: [offerId], references: [id])
  inviter User     @relation("InvitationsSent", fields: [invitedBy], references: [id])
  user    User?    @relation("InvitationsReceived", fields: [userId], references: [id])

  @@map("invitations")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        Int              @id @default(autoincrement())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String?
  read      Boolean          @default(false)
  readAt    DateTime?        @map("read_at")
  deepLink  String?          @map("deep_link")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")
  deleted   Boolean          @default(false)

  user User @relation("NotificationRecipient", fields: [userId], references: [id])

  @@map("notifications")
}

model ExpoPushToken {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  token     String   @unique
  deviceId  String?  @map("device_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deleted   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])

  @@map("expo_push_tokens")
}

// ─── Stations ───────────────────────────────────────────────────────────


model Station {
  id              Int      @id @default(autoincrement())
  createdAt        DateTime @default(now())
  deleted          Boolean  @default(false)
  name             String   @unique
  countryId        Int      @map("country_id")
  officeAddressId  Int      @map("office_address_id")

  country          Country  @relation(fields: [countryId], references: [id])
  officeAddress    Address  @relation("StationOfficeAddress", fields: [officeAddressId], references: [id])

  companies        Company[]

  @@map("stations")
}

// ─── Reference Data ───────────────────────────────────────────────────────────

model Country {
  id             Int    @id @default(autoincrement())
  name           String
  nativeName     String @map("native_name")
  code           String @unique
  phoneIndicatif String @map("phone_indicatif")
  nationality    String @unique

  addresses Address[]
  stations  Station[]
  users     User[]

  @@map("countries")
}


model Language {
  id   Int    @id @default(autoincrement())
  code String @unique
  name String @unique

  users User[]

  @@map("languages")
}

// ─── Posts ────────────────────────────────────────────────────────────────────

enum PostVisibility {
  PUBLIC   // visible par tous les utilisateurs connectés
  COMPANY  // visible uniquement par les workers de la company de l'auteur
}

model Post {
  id         Int            @id @default(autoincrement())
  authorId   String         @map("author_id")
  companyId  String?        @map("company_id")
  title      String
  content    String?
  imageUrl   String?        @map("image_url")
  link       String?
  visibility PostVisibility @default(PUBLIC)
  deleted    Boolean        @default(false)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  author  User     @relation("PostAuthor", fields: [authorId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])

  @@map("posts")
}
