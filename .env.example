# URL(s) autorisée(s) pour CORS (virgule si plusieurs). Ex: http://localhost:5173,https://app.tumavu.com
FRONTEND_URL="http://localhost:5173"
# URL de connexion PostgreSQL pour Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tumavu?schema=public"
# Port HTTP du serveur NestJS.
PORT=3000
# Environnement d'execution.
# development | production | test | preproduction
NODE_ENV=development
# Secret HMAC pour signer les tokens d'auth.
AUTH_TOKEN_SECRET="change-me-super-secret"
# SUPABASE URL pour stockage des fichiers.
SUPABASE_URL="https://your-supabase-url.supabase.co"
# SUPABASE KEY pour accès au stockage de fichiers.
SUPABASE_SERVICE_ROLE_KEY="change-me-super-secret"
# Bucket storage Supabase cible (ex: public, avatars).
SUPABASE_STORAGE_BUCKET="users"

# Clé secrète pour le bootstrap des admins (à utiliser depuis Insomnia/Postman).
ADMIN_BOOTSTRAP_KEY='change-me-super-secret'

# Adresse email d'envoi des invitations.
MAIL_FROM='email@send_invitation.com'
# Clé API Resend pour l'envoi des emails d'invitation.
RESEND_API_KEY='change-me-super-secret'

# URL de l'application (utilisée dans les emails d'invitation).
APP_URL='http://localhost:5173'

